VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Unified app shell (canopy header, Activity / Manage data on desktop, compact “Menu” on small screens).
# Default: enabled. Set to false only to restore legacy per-page green headers (comparison / debug).
# VITE_EXPERIMENTAL_NAV=false

# v2: use Postgres via Supabase instead of DuckDB + Parquet (Phase 3+).
# VITE_USE_SUPABASE=true
# Optional: auto anonymous auth so RLS (authenticated) policies work locally (pre-migration 019 style).
# Enable "Anonymous sign-ins" in Supabase → Authentication → Providers first.
# After migration 019, anonymous JWTs cannot read app tables — prefer real sign-in for local dev.
# VITE_SUPABASE_AUTO_ANON_AUTH=true
# Invite-only magic link (Edge Function request-magic-link + signup_allowlist). Mutually exclusive with auto anon in prod.
# VITE_REQUIRE_EMAIL_AUTH=true
# Production: Anonymous provider OFF in Supabase; VITE_SUPABASE_AUTO_ANON_AUTH unset/false; apply migration 019 (see docs/plans/production-hardening-anon-auth.md).

# --- Vercel (Phase 7) — set in Project → Settings → Environment Variables, not committed ---
# VITE_USE_SUPABASE=true
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_BASE=/   (use default / for apex or Vercel-assigned .vercel.app URL)

# --- GitHub Actions: ingest → Supabase (repository secrets) ---
# SUPABASE_URL
# SUPABASE_SERVICE_KEY   service role / sb_secret_… (never commit; not the anon key)
# POKEMON_TCG_API_KEY    optional; higher rate limits on pokemontcg.io
